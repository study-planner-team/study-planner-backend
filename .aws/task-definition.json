{
  "family": "study-planner-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::114872709698:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "study-planner-api",
      "image": "114872709698.dkr.ecr.eu-central-1.amazonaws.com/namespace/image:tag",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "FrontendUrl",
          "value": "http://localhost:3000"
        },
        {
          "name": "Jwt__Issuer",
          "value": "myAppIssuer"
        },
        {
          "name": "Jwt__Audience",
          "value": "myAppAudience"
        }
      ],
      "secrets": [
        {
          "name": "Jwt__Key",
          "valueFrom": "/study-planner/prod/jwt/key"
        },
        {
          "name": "ConnectionStrings__DbConnString",
          "valueFrom": "/study-planner/prod/db/connection-string"
        }
      ]
    }
  ]
}